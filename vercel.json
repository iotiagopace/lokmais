{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/:slug((?!planos|como-funciona|contato|faq|motos|seja-franqueado|sobre|unidades|admin|00-sistema-de-design|assets|api|unidade)([a-z0-9][a-z0-9-]*))",
      "destination": "/unidade.html"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/simulador",
      "destination": "/planos",
      "permanent": true
    },
    {
      "source": "/simulador.html",
      "destination": "/planos",
      "permanent": true
    },
    {
      "source": "/lp-seja-franqueado.html",
      "destination": "/seja-franqueado",
      "permanent": true
    },
    {
      "source": "/lp-seja-franqueado",
      "destination": "/seja-franqueado",
      "permanent": true
    },
    {
      "source": "/seja-franqueado.html",
      "destination": "/seja-franqueado",
      "permanent": true
    },
    {
      "source": "/sejafranqueado.html",
      "destination": "/seja-franqueado",
      "permanent": true
    },
    {
      "source": "/sejafranqueado",
      "destination": "/seja-franqueado",
      "permanent": true
    }
  ]
}
